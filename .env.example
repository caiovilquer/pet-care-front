# Variáveis de Ambiente - Copie este arquivo para .env e configure suas chaves

# URL usada pelo Angular (sempre relativa com proxy)
API_URL=/api/v1

# URL real do backend — usada pelo proxy local e pelo serverless no Vercel
# Não commitar em vercel.json; configure como variável de ambiente no painel do Vercel
API_BACKEND_URL=https://pet-care.com.br/api/v1

# Chave da API do Google Maps
# Obtenha sua chave em: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=sua-chave-real-do-google-maps-aqui

# Proxy local (proxy.conf.js) aponta para https://localhost:8443 por padrão.
# Para apontar para o Railway em dev, altere o target em proxy.conf.js.
